{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the MathGPT app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Query": {
      "title": "Query",
      "description": "A math problem solved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The query's unique ID." },
        "userId": { "type": "string", "description": "The ID of the user who created the query." },
        "text": { "type": "string", "description": "The text of the math problem." },
        "imageUrl": { "type": "string", "format": "uri", "description": "The URL of the uploaded image (optional)." },
        "result": { "type": "string", "description": "The AI-generated solution." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the query was created." }
      },
      "required": ["id", "userId", "result", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/queries/{queryId}": {
      "schema": { "$ref": "#/entities/Query" },
      "description": "Stores math queries and solutions."
    }
  }
}
